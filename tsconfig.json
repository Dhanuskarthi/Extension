{
    "compilerOptions": {
        "target": "ES2022",
        "useDefineForClassFields": true,
        "lib": [
            "ES2022",
            "DOM",
            "DOM.Iterable"
        ],
        "module": "ESNext",
        "skipLibCheck": true,
        /* Bundler mode */
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        /* Linting */
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noFallthroughCasesInSwitch": true,
        /* Path aliases */
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "src/*"
            ],
            "@shared/*": [
                "src/shared/*"
            ],
            "@background/*": [
                "src/background/*"
            ],
            "@content/*": [
                "src/content/*"
            ]
        },
        /* Types */
        "types": [
            "chrome",
            "webextension-polyfill"
        ]
    },
    "include": [
        "src/**/*.ts",
        "vite.config.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}